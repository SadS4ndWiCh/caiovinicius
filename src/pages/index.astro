                    hi@caiovinicius.xyz
                </a>
            </li>
            <li>
                <a href="/caiovinicius-public-key.asc" download class="underline underline-offset-2 text-purple-800 dark:text-purple-300">
                    public gpg
                </a>
            </li>
            <li>
                <a href="/cv.pdf" target="_blank" class="underline underline-offset-2 text-purple-800 dark:text-purple-300">
                    cv
                </a>
            </li>
        </ul>
    </main>

    <footer class="flex justify-between pt-4 border-t border-zinc-400 text-sm text-zinc-600">
        <span>Caio Vinícius</span>
        <span>&copy; 2022 - 2026</span>
    </footer>
</PageLayout>
