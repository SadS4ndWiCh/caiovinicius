---
import "~/styles/global.css";

interface Props {
  title?: string;
}

const title = Astro.props.title
  ? Astro.props.title.concat(" - Caio Vinícius")
  : "Caio Vinícius";
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
</head>
<body class="max-w-[605px] mx-auto px-4 sm:px-0 py-4 sm:py-16 antialiased text-zinc-900 font-[Inter] dark:bg-zinc-950 dark:text-zinc-100">
    <slot />
</body>
</html>
